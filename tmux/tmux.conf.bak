unbind C-b
set-option -g prefix M-q
bind-key M-q send-prefix

set -g status-left ""
set -g status-right ""
set -g status 2
set -g status-style "bg=colour235,fg=colour250"
set -g window-status-current-style "fg=colour255,bold"
set -g status-format[1] '#[align=left,bg=colour234,fg=colour248] #(echo "#{pane_current_path}" | sed "s|$HOME|~|") #[fg=colour114]#(~/.claude/tmux/tmux-git-diff.sh "#{pane_current_path}")#[align=right,fg=colour109]#(~/.claude/tmux/tmux-git-status.sh "#{pane_current_path}") '

set -g default-terminal "tmux-256color"
set -g history-limit 50000
set -g renumber-windows on
set -g allow-passthrough on

# M-q f — toggle git changed-files tree in a right split pane (35% width)
bind-key f run-shell "~/.claude/tmux/tmux-toggle-git-tree.sh"
